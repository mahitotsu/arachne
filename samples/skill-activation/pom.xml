<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>4.0.5</version>
        <relativePath/>
    </parent>

    <groupId>io.arachne.samples</groupId>
    <artifactId>skill-activation</artifactId>
    <version>0.1.0-SNAPSHOT</version>
    <name>Arachne Skill Activation Sample</name>
    <description>Sample Spring Boot application for delayed skill activation and skill-state restore</description>

    <properties>
        <java.version>25</java.version>
        <bytebuddy.agent.version>1.17.8</bytebuddy.agent.version>
        <test.jvm.args>-Xshare:off --enable-native-access=ALL-UNNAMED --sun-misc-unsafe-memory-access=allow</test.jvm.args>
        <argLine></argLine>
    </properties>

    <dependencies>
        <dependency>
            <groupId>io.arachne</groupId>
            <artifactId>arachne</artifactId>
            <version>0.1.0-SNAPSHOT</version>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>net.bytebuddy</groupId>
            <artifactId>byte-buddy-agent</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <argLine>${argLine} -javaagent:${settings.localRepository}/net/bytebuddy/byte-buddy-agent/${bytebuddy.agent.version}/byte-buddy-agent-${bytebuddy.agent.version}.jar ${test.jvm.args}</argLine>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>