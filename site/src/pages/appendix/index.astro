---
import PageHero from '../../components/PageHero.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';

const designRows = [
  {
    principle: 'AI エージェントは自然言語フロントドアとして追加する',
    impl: 'order-service に order-intake-agent を置いてユーザー入力の一次解釈を担わせ、menu-service・delivery-service・support-service は service-local agent として catalog grounding、ETA 判断、サポート対話を担わせます',
    check: 'order-service の suggest API が direct item request / recommendation request を正規化し、その handoff を受けた menu-service が明示指定優先で grounded な候補を返す流れで確認できます',
  },
  {
    principle: '従来の API は機械間連携の正本契約として残す',
    impl: '全サービスが REST API と OpenAPI 仕様を公開し、エージェントはその API をツールとして呼び出す形を維持します',
    check: '/agents の API 仕様タブから各サービスの OpenAPI を確認できます。エージェントのツール定義も同じ API 上に乗っています',
  },
  {
    principle: '金額計算・課金・認可は決定論的コードで処理する',
    impl: 'payment-service はエージェントを持たず、支払い準備と課金確定をコードで完結させます',
    check: 'payment-service の /v3/api-docs で intent.rawMessage を受け取り、PaymentProfileRepository が決定論的に処理することを確認できます',
  },
  {
    principle: 'system prompt はエンジニアが管理するシステム制約として書く',
    impl: '各エージェントの system prompt はソースコード中に置き、役割・制約・ツール利用方針・言語設定を明示します',
    check: '/agents のサービスカードを開くと、登録済みの system prompt をそのまま読めます',
  },
  {
    principle: 'skill は業務知識の公開面として分離する',
    impl: 'menu-service と kitchen-service は商品説明・推薦ロジック・仕込みスケジュール方針を SKILL.md に分離し、ResourceLoader で読み込みます。さらに menu-service はスキル発動条件も SKILL.md の activationHint フロントマターに記述し、MenuServiceConfiguration が起動時にパースしてシステムプロンプトへ動的に注入します。スキル内容だけでなくスキル選択条件自体が SKILL.md に集約されており、業務担当者がコード変更なしにメンテできる構造になっています',
    check: '/agents のスキルタブで system prompt とは別に管理されているスキルドキュメントを確認できます。proactive-recommendation と family-order-guide の SKILL.md に activationHint が定義されており、これがそのままエージェントのスキル発動セクションに変換されます',
  },
  {
    principle: 'サービス間の collaborator 解決は capability ベースで動的に行う',
    impl: 'order / kitchen / menu / support / delivery が起動時に registry-service へ自己登録し、ダウンストリーム解決は POST /registry/discover で行います',
    check: 'delivery-service が hermes-adapter と idaten-adapter を discover 経由で発見し、ETA を比較して推奨を返すフローで確認できます',
  },
  {
    principle: '会話責務・workflow 責務・仕様閲覧責務は UI レベルでも分離する',
    impl: 'カスタマー UI を /order（workflow）・/support（会話）・/agents（viewer）の 3 ページに分け、責務を混在させません',
    check: '/support は注文フローと独立しており、/order での workflow 処理中でも別タブでサポートに問い合わせできます',
  },
];

const artifactRows = [
  {
    artifact: 'OpenAPI（/v3/api-docs）',
    location: '全 10 サービスが各自 /v3/api-docs と /swagger-ui.html を公開しています。認証が必要なサービスも /v3/api-docs は匿名アクセスを許可しています',
    purpose: 'エージェントのツール定義と REST API 仕様を同一の contract として管理し、実装と説明が乖離しない状態を保ちます',
  },
  {
    artifact: 'x-ai-prompt-contract',
    location: 'order・delivery・payment 等の AI 向け operation に OpenAPI extension として付与しています。requiredInputs / optionalInputs / serviceBehavior を持ちます',
    purpose: 'prompt を黒箱のままにせず、エージェントが期待する入力構造とサービスの振る舞いを OpenAPI 上で読めるようにします',
  },
  {
    artifact: '実行履歴（/execution-history/{sessionId}）',
    location: 'order / menu / kitchen / delivery / support の 5 サービスが /execution-history/{sessionId} を公開しています。カスタマー UI がファンアウトして時系列集約します',
    purpose: 'エージェントがどのツールをどの順序で呼び出し、どの結果を受け取ったかを利用者が追えます。開発者向けトレースではなくユーザー向け証跡として設計しています',
  },
  {
    artifact: 'Micrometer メトリクス（/actuator/metrics）',
    location: 'delivery.order.workflow（ワークフロー入口）・delivery.order.downstream（各ゲートウェイ呼び出し）・delivery.order.registry.lookup・delivery.agent.* を計測しています',
    purpose: 'エージェント経由の処理でも「どこで時間がかかるか」「registry lookup は何回成功しているか」を数値で観測できます',
  },
  {
    artifact: 'Registry API の 2 分割',
    location: 'POST /registry/discover がランタイムの collaborator resolution 用。GET /registry/services が viewer / inventory 用です',
    purpose: 'サービスメッシュの経路解決と UI の棚卸し表示を別 API に分けることで、設計意図がそのまま API 構造に見えます',
  },
];
---

<SiteLayout title="Appendix | Arachne Field Notes">
  <PageHero
    eyebrow="Appendix"
    title="設計仮説と実装の対応、および技術的証拠"
    summary="このページは 2 つの目的を持ちます。ひとつは設計仮説が food-delivery-demo のどの実装に対応しているかの確認。もうひとつは、その主張を裏付ける OpenAPI・実行履歴・メトリクスといった技術的証拠の参照です。"
  />

  <section class="panel">
    <p class="panel__eyebrow">このページの使い方</p>
    <p>
      上の表（設計仮説との対応）は <strong>「なぜそう設計したか」</strong> を確認するためのものです。
      下の表（技術的証拠）は <strong>「その設計が実際に実装されているか」</strong> を確認するためのものです。
      Demo ページでサービス構成を把握した後に、このページで設計の根拠と証拠を追うという順番で読むのがおすすめです。
    </p>
  </section>

  <section>
    <h2 style="font-size:1.05rem; font-weight:700; margin-bottom:16px; color:var(--text-muted); letter-spacing:0.02em; text-transform:uppercase; font-family:var(--font-mono)">設計仮説と実装の対応</h2>
    <div class="table-shell">
      <table>
        <thead>
          <tr>
            <th>設計仮説の原則</th>
            <th>food-delivery-demo での実装</th>
            <th>どこで確認できるか</th>
          </tr>
        </thead>
        <tbody>
          {designRows.map((row) => (
            <tr>
              <td>{row.principle}</td>
              <td>{row.impl}</td>
              <td>{row.check}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <h2 style="font-size:1.05rem; font-weight:700; margin-bottom:16px; color:var(--text-muted); letter-spacing:0.02em; text-transform:uppercase; font-family:var(--font-mono)">技術的証拠</h2>
    <div class="table-shell">
      <table>
        <thead>
          <tr>
            <th>証拠</th>
            <th>どこにあるか</th>
            <th>何を示しているか</th>
          </tr>
        </thead>
        <tbody>
          {artifactRows.map((row) => (
            <tr>
              <td style="white-space:nowrap">{row.artifact}</td>
              <td>{row.location}</td>
              <td>{row.purpose}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="two-column-band">
    <article class="panel">
      <p class="panel__eyebrow">Arachne コアと food-delivery-demo の関係</p>
      <p>
        Arachne は food-delivery-demo のために作ったフレームワークではなく、Spring になじむ汎用エージェント実行基盤として独立したライブラリです。
        food-delivery-demo は Arachne を依存として追加し、<code>AgentFactory</code> と <code>ArachneAutoConfiguration</code> を通じて Agent を Spring Bean として登録しています。
      </p>
      <p style="margin-top:12px">
        Arachne 自体のソースコードは <code>arachne/</code> モジュールにあり、<code>mvn test</code> で単体テストを実行できます。
        food-delivery-demo のビルドは <code>mvn -f food-delivery-demo/pom.xml test</code> で実行します。
      </p>
    </article>
    <article class="panel panel--soft">
      <p class="panel__eyebrow">未解決の設計問題</p>
      <p>現時点でまだ答えが固まっていない、あるいは意図的に先送りしている問題があります。</p>
      <ul>
        <li>interrupt（human-in-the-loop）と構造化出力の組み合わせ時のセッション復元方法</li>
        <li>skill ドキュメントの変更がエージェントの振る舞いに与える影響をどうテストするか</li>
        <li>registry-service のストレージが現状インメモリのため、再起動時に再登録が必要</li>
        <li>capability-based discovery と Spring Cloud の service registry の位置づけの整理</li>
      </ul>
    </article>
  </section>
</SiteLayout>
