---
import { getCollection, render } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry, essays },
  }));
}

const { entry, essays } = Astro.props;
const { Content } = await render(entry);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const isMain = entry.data.order === 1;
const mainEssay = essays.find((e: typeof entry) => e.data.order === 1)!;
const derivedEssays = essays
  .filter((e: typeof entry) => e.data.order > 1)
  .sort((a: typeof entry, b: typeof entry) => a.data.order - b.data.order);
---

<SiteLayout title={`${entry.data.title} | Arachne Field Notes`} description={entry.data.summary}>
  <article class="article-shell">
    {!isMain && (
      <a class="back-link" href={`${base}/essay/${mainEssay.slug}`}>
        ← 本編：{mainEssay.data.title}
      </a>
    )}
    <header class="article-header">
      <p class="panel__eyebrow">{isMain ? 'Essay — 本編' : 'Essay — 深掘り'}</p>
      <h1>{entry.data.title}</h1>
      <p>{entry.data.summary}</p>
      <div class="tag-row">
        {entry.data.tags.map((tag: string) => (
          <span class="tag-chip">{tag}</span>
        ))}
      </div>
    </header>
    <div class="article-body">
      <Content />
    </div>
    {isMain && (
      <div class="derived-nav">
        <p class="panel__eyebrow">深掘り記事</p>
        <div class="derived-nav__grid">
          {derivedEssays.map((essay: typeof entry) => (
            <a class="derived-nav-card" href={`${base}/essay/${essay.slug}`}>
              <span>{essay.data.title}</span>
              <p>{essay.data.summary}</p>
            </a>
          ))}
        </div>
      </div>
    )}
  </article>
</SiteLayout>