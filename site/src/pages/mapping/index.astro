---
import PageHero from '../../components/PageHero.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';

const rows = [
  {
    surface: '/order',
    runtime: 'order-service の step API + menu/delivery/payment 連携',
    explanation: '注文は 4 段階 workflow で確定責務を前に出す。',
    evidence: 'suggest -> item-selection -> delivery-selection -> payment-approval の構造化レスポンスと理由表示。',
  },
  {
    surface: '/support',
    runtime: 'support-service の FAQ / campaigns / status / feedback',
    explanation: '会話型 UX は注文面から分離し、サポート業務にだけ使う。',
    evidence: 'FAQ と問い合わせに加え、post-order support や `[HANDOFF: order]` を conversational に返せること。',
  },
  {
    surface: '/agents',
    runtime: 'registry-service inventory + 各 service の OpenAPI / prompt contract',
    explanation: 'viewer は runtime collaborator ではなく、説明と棚卸しの公開面として切り出す。',
    evidence: 'GET /registry/services から service card を出し、prompt、skill、OpenAPI、x-ai-prompt-contract を読めること。',
  },
  {
    surface: 'Execution history',
    runtime: '5 service の /execution-history/{sessionId} 集約',
    explanation: '証跡は内部 trace の断片ではなく、利用者が workflow の裏側を追える proof surface にする。',
    evidence: 'service、category、outcome、skill、tool、token usage を時系列に再読込できること。',
  },
  {
    surface: 'Registry boundary',
    runtime: 'POST /registry/discover と GET /registry/services の分離',
    explanation: 'collaborator resolution と inventory/viewer を API レベルで分ける。',
    evidence: 'delivery-service などの downstream 解決は discover を使い、/agents の一覧表示は services API を使うこと。',
  },
  {
    surface: 'Deterministic payment',
    runtime: 'payment-service の決定論的 payment preparation / charge',
    explanation: 'すべてを agent 化せず、正確性が要る責務はコードで閉じる。',
    evidence: '支払い方法提示と課金確定が prompt に依存せず、workflow の最終確定点として残っていること。',
  },
];

const checklist = [
  'workflow、support、viewer、proof surface が別々の公開面として語れているか。',
  'discover API と inventory API の役割が混ざっていないか。',
  'execution history と OpenAPI が、実装確認の証拠面としてつながっているか。',
  'deterministic な確定責務と agent 的な説明責務が、同じ列で混線していないか。',
];
---

<SiteLayout title="Mapping | Arachne Field Notes">
  <PageHero
    eyebrow="Mapping"
    title="公開面と runtime 証拠の対応表"
    summary="抽象的な AI-native microservices 論ではなく、food-delivery-demo で今どの公開面が出荷され、どの runtime artifact がその主張を裏づけているかを対応づけます。"
  />

  <section class="two-column-band">
    <article class="panel">
      <p class="panel__eyebrow">How To Use This Page</p>
      <p>
        このページは future plan の表ではない。
        読者が demo を開いたときに、各公開面がどの runtime artifact と結びついているかを手早く確認するための evidence map である。
      </p>
    </article>
    <article class="panel panel--warm">
      <p class="panel__eyebrow">Checklist</p>
      <ul>
        {checklist.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </article>
  </section>

  <section class="table-shell">
    <table>
      <thead>
        <tr>
          <th>公開面</th>
          <th>対応する runtime</th>
          <th>何を示しているか</th>
          <th>見える証拠</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr>
            <td>{row.surface}</td>
            <td>{row.runtime}</td>
            <td>{row.explanation}</td>
            <td>{row.evidence}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</SiteLayout>