---
import PageHero from '../../components/PageHero.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';

const surfaces = [
  {
    name: '/order',
    role: '4-step workflow-first ordering UI',
    fit: '注文面は入力整理、候補選択、配送選択、支払い承認を段階的に進める workflow-first の公開面として出荷されている。',
    check: 'order-service の step API が構造化レスポンスを返し、選択理由と確定責務を workflow 側に残していること。',
  },
  {
    name: '/support',
    role: 'conversational support surface',
    fit: '会話面は注文 UI から分離され、FAQ、問い合わせ、キャンペーン、運用状態確認を扱う専用公開面として残している。',
    check: 'support-service が注文後導線や `[HANDOFF: order]` を含めて、workflow とは別責務の conversational front door になっていること。',
  },
  {
    name: '/agents',
    role: 'registry-backed viewer',
    fit: '説明面は別ページに分離し、ケイパビリティ、プロンプト、スキル、OpenAPI を inventory/viewer として読む形にしている。',
    check: 'GET /registry/services と各 service の OpenAPI を使い、viewer 用 inventory と runtime 契約を同じ画面で説明できること。',
  },
  {
    name: 'Execution History',
    role: 'user-facing proof surface',
    fit: '内部の開発者向けトレースに閉じず、ユーザーが各ステップのサービス実行と判断理由を辿れる証跡として見せている。',
    check: 'step 1 以降の UI から再読込でき、service、category、outcome、tool 使用、token usage が見えること。',
  },
  {
    name: 'Registry API split',
    role: 'discover-vs-inventory boundary',
    fit: 'service-to-service collaborator resolution と viewer/inventory を別 API に分け、公開説明でもその境界を隠さない。',
    check: 'POST /registry/discover は downstream 解決、GET /registry/services は viewer/inventory 用として語り分けられていること。',
  },
];

const shippedSurfaces = [
  '注文は /order の 4-step workflow UI で進み、会話面とは分離されている。',
  '問い合わせは /support に寄せ、FAQ と post-order support を conversational に扱う。',
  '/agents は registry-backed viewer として capability、prompt、skill、API を一覧できる。',
  'execution history は利用者向けの proof surface として独立に露出している。',
];

const evidenceAnchors = [
  'workflow/support/viewer の 3 面が UI 上で明確に分かれていること。',
  'OpenAPI と x-ai-prompt-contract が /agents から辿れること。',
  'delivery-service の候補比較が discover API に立脚していること。',
  'inventory API と collaborator discovery API が混同されていないこと。',
];
---

<SiteLayout title="Demo | Arachne Field Notes">
  <PageHero
    eyebrow="Demo"
    title="food-delivery-demo の公開面を shipped runtime に合わせて読む"
    summary="food-delivery-demo は未来の構想ではなく、すでに workflow-first ordering、support chat、registry-backed viewer、execution history を並立させている実行中の proof surface です。"
    aside="ここで見るべきなのは agent の数ではなく、どの公開面をどの UX で見せ、どの証跡で裏づけているかです。"
  />

  <section class="two-column-band">
    <article class="panel">
      <p class="panel__eyebrow">Shipped Surfaces</p>
      <ul>
        {shippedSurfaces.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </article>
    <article class="panel panel--warm">
      <p class="panel__eyebrow">Evidence Anchors</p>
      <ul>
        {evidenceAnchors.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </article>
  </section>

  <section class="stacked-list">
    {surfaces.map((surface) => (
      <article class="essay-card">
        <div>
          <p class="panel__eyebrow">Public Surface</p>
          <h2>{surface.name}</h2>
          <p>{surface.role}</p>
        </div>
        <div>
          <p class="panel__eyebrow">What It Proves</p>
          <p>{surface.fit}</p>
        </div>
        <div>
          <p class="panel__eyebrow">Runtime Anchor</p>
          <p>{surface.check}</p>
        </div>
      </article>
    ))}
  </section>
</SiteLayout>