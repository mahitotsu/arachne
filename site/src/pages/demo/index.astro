---
import PageHero from '../../components/PageHero.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';

const services = [
  {
    name: 'order-service',
    port: '8080',
    role: '注文ワークフロー coordinator',
    agent: true,
    note: '4 ステップの workflow API（suggest → confirm-items → confirm-delivery → confirm-payment）を持ちます。menu / delivery / payment / support をダウンストリームに持ち、registry 経由で動的に解決します。',
  },
  {
    name: 'menu-service',
    port: '8081',
    role: 'メニュー提案・合計計算',
    agent: true,
    note: '曘昧な注文意図を具体的な商品提案に変換します。catalog_lookup・calculate_total ツールを持ち、欠品時は kitchen-service と連携して代替候補を提示します。',
  },
  {
    name: 'kitchen-service',
    port: '8082',
    role: 'キッチン状況管理',
    agent: true,
    note: '厄房のキャパシティと仕込み状況を管理します。注文確定時に準備スケジュールを調整し、混雑時は代替提案をエージェントが生成します。',
  },
  {
    name: 'delivery-service',
    port: '8083',
    role: '配送 ETA 評価・推奨',
    agent: true,
    note: 'registry-service を通じて外部 ETA サービスを動的に発見し、自社急配と比較して推奨配送プランを返します。capability-based discovery の主な実証箇所です。',
  },
  {
    name: 'payment-service',
    port: '8084',
    role: '支払い処理',
    agent: false,
    note: 'エージェントを持ちません。支払い準備と課金確定は決定論的コードで実行します。「正解が必要な処理はコードで守る」という設計方针の体現です。',
  },
  {
    name: 'customer-service',
    port: '8085',
    role: '認証・顧客情報管理',
    agent: false,
    note: 'デモアカウント認証（demo/demo-pass など）と顧客プロフィールを提供します。JWT 発行と JWKS 公開を担い、他サービスがトークンを検証します。',
  },
  {
    name: 'support-service',
    port: '8086',
    role: '会話型サポート窓口',
    agent: true,
    note: '注文フローとは分離した会話インターフェースです。FAQ・キャンペーン・サービス稼働状況・注文後フォローを扱います。[HANDOFF: order] で注文ページへの誘導も行います。',
  },
  {
    name: 'registry-service',
    port: '8087',
    role: 'サービス登録・capability 検索',
    agent: false,
    note: '各サービスが起動時に自己登録します。POST /registry/discover がランタイムの collaborator resolution、GET /registry/services が viewer/inventory 用と、2 つの API を意図的に分けています。',
  },
  {
    name: 'hermes-adapter',
    port: '8088',
    role: '外部 ETA アダプター（常に遅延）',
    agent: false,
    note: '外部配送会社のモックです。15 秒サイクルで周期的に停止します。delivery-service が外部候補の可用性変動を正しく処理するかを検証できます。',
  },
  {
    name: 'idaten-adapter',
    port: '8089',
    role: '外部 ETA アダプター（常に最速）',
    agent: false,
    note: '外部配送会社のモックです。常に最短 ETA で AVAILABLE を返します。hermes-adapter と対にすることで、delivery-service の比較ロジックが機能することを確認できます。',
  },
];

const surfaces = [
  {
    path: '/order',
    title: '4 ステップ注文 UI',
    steps: ['意図入力', '商品選択', '配送選択', '支払い確認'],
    desc: 'ユーザーの注文意図を段階的に確定させる workflow-first UI です。各ステップで AI が提案と理由を返し、ユーザーが選択・調整します。会話的な自由入力と structured workflow の組み合わせが特徴です。',
  },
  {
    path: '/support',
    title: '会話型サポート',
    steps: ['FAQ', 'キャンペーン', '稼働状況確認', '注文後フォロー'],
    desc: '注文フローとは分離したサポート専用の会話窓口です。support-service のエージェントが対話を担います。注文関連の問い合わせには [HANDOFF: order] リンクで /order に誘導できます。',
  },
  {
    path: '/agents',
    title: 'サービスビューワー',
    steps: ['サービス一覧', 'プロンプト確認', 'スキル一覧', 'OpenAPI 仕様'],
    desc: 'registry-service の GET /registry/services を使い、登録済みサービスのカード一覧を表示します。各カードからシステムプロンプト・スキル・OpenAPI 仕様（x-ai-prompt-contract 含む）を確認できます。',
  },
];
---

<SiteLayout title="Demo | Arachne Field Notes">
  <PageHero
    eyebrow="Demo"
    title="food-delivery-demo ── 10 サービスで仮説を検証する実証環境"
    summary="food-delivery-demo はクラウドキッチンの注文・配送システムを実装したデモアプリケーションです。どのサービスにエージェントを置き、どこに置かないかを意図的に設計し、AI 時代のマイクロサービス設計仮説を動くコードで示します。"
  />

  <section class="panel">
    <p class="panel__eyebrow">デモを読む上での視点</p>
    <p>
      このデモで重要なのはエージェントの数ではなく、<strong>エージェントを持つサービスと持たないサービスの対比</strong>です。
      menu / delivery / support はエージェントが自然言語の解釈を担い、payment / customer / registry は決定論的コードで責務を果たします。
      この設計の違いが「自然言語フロントドア」という仮説の実装上の答えです。
    </p>
  </section>

  <section class="table-shell">
    <table>
      <thead>
        <tr>
          <th>サービス</th>
          <th>ポート</th>
          <th>役割</th>
          <th>エージェント</th>
          <th>設計ポイント</th>
        </tr>
      </thead>
      <tbody>
        {services.map((s) => (
          <tr>
            <td><code>{s.name}</code></td>
            <td>{s.port}</td>
            <td>{s.role}</td>
            <td style="white-space:nowrap">{s.agent ? '✓ あり' : '─ なし'}</td>
            <td>{s.note}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="stacked-list">
    <h2 style="font-size:1.1rem; color:var(--text-muted); font-weight:600; margin-bottom:-8px">カスタマー UI の 3 つの公開面</h2>
    {surfaces.map((s) => (
      <article class="essay-card">
        <div>
          <p class="panel__eyebrow">{s.path}</p>
          <h2>{s.title}</h2>
          <p>{s.desc}</p>
        </div>
        <div class="tag-row">
          {s.steps.map((step) => (
            <span class="tag-chip">{step}</span>
          ))}
        </div>
      </article>
    ))}
  </section>

  <section class="two-column-band">
    <article class="panel">
      <p class="panel__eyebrow">起動方法</p>
      <p>
        リポジトリの <code>food-delivery-demo/</code> ディレクトリで <code>make up</code> を実行すると、
        Docker Compose で全サービスが起動します。Bedrock を使う場合は <code>make up-bedrock</code>。
        AWS 認証情報は <code>aws configure export-credentials</code> 経由で渡されます。
      </p>
    </article>
    <article class="panel panel--soft">
      <p class="panel__eyebrow">実行履歴（Execution History）について</p>
      <p>
        注文ワークフローの各ステップを進めると、5 サービスの実行イベントが時系列で記録されます。
        <code>/order</code> の UI から「実行履歴」パネルを開くと、サービス・カテゴリ・結果・ツール使用・トークン消費を確認できます。
        エージェントの判断過程を追うための証拠面として設計しています。
      </p>
    </article>
  </section>
</SiteLayout>
