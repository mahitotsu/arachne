---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Arachne の思想、実装、デモを束ねる長編サイト。' } = Astro.props;

const navItems = [
  { href: '/', label: 'Top' },
  { href: '/essay', label: 'Essay' },
  { href: '/demo', label: 'Demo' },
  { href: '/mapping', label: 'Mapping' },
  { href: '/appendix', label: 'Appendix' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="bg-orb bg-orb--left"></div>
    <div class="bg-orb bg-orb--right"></div>
    <div class="site-shell">
      <header class="site-header">
        <a class="site-brand" href="/">
          <span class="site-brand__mark">A</span>
          <span>
            <strong>Arachne Field Notes</strong>
            <small>AI era microservices</small>
          </span>
        </a>
        <nav class="site-nav" aria-label="primary">
          {navItems.map((item) => (
            <a class:list={["site-nav__link", { 'is-active': currentPath === item.href || currentPath.startsWith(`${item.href}/`) }]} href={item.href}>
              {item.label}
            </a>
          ))}
        </nav>
      </header>
      <main class="site-main">
        <slot />
      </main>
      <footer class="site-footer">
        <p>仮説、SDK、food-delivery-demo を 1 本のストーリーとして編み直すための静的サイト。</p>
      </footer>
    </div>
  </body>
</html>